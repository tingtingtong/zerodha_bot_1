# Copy this to .env and fill in your values
# NEVER commit .env to git

ZERODHA_API_KEY=your_api_key_here
ZERODHA_API_SECRET=your_api_secret_here

# Required for auto-login (brokers/zerodha_auto_login.py)
ZERODHA_USER_ID=your_client_id        # e.g. AB1234
ZERODHA_PASSWORD=your_login_password
ZERODHA_TOTP_SECRET=your_base32_totp_secret  # shown when you enrolled 2FA in Zerodha

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

NEWSAPI_KEY=your_newsapi_key_optional

BOT_MODE=paper
